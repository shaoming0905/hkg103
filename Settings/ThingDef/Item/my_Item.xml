            <MaxStack>500</MaxStack>
            <Beauty>10</Beauty>
            <Rate>6</Rate>
            <Color>#ffffff</Color>
            <Item Lable="Cloth">
                <NotFengshuiItem>1</NotFengshuiItem>
                <NotRandom>1</NotRandom>
                <BeMaterial>
                    <NamePrefix>灵布</NamePrefix>
                    <RateWhenBeMain>6</RateWhenBeMain>
                    <LingShieldWhenBeMain>0.05</LingShieldWhenBeMain>
                    <TemperatureMaxAddWhenBeMain>30</TemperatureMaxAddWhenBeMain>
                    <TemperatureMinAddWhenBeMain>-20</TemperatureMinAddWhenBeMain>
                </BeMaterial>
                <BeMade>
                    <WorkToMake>20</WorkToMake>
                    <CostItems><Item name="Item_LingStone" count="1"/></CostItems>
                </BeMade>
            </Item>
        </ThingDef>

