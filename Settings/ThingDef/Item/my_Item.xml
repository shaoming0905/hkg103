<ThingDefs>
    <List>
        <ThingDef Type="Item" Name="my_Sword_GuiRen" Parent="WeaponBase">
            <ThingName>聚气剑</ThingName>
            <TexPath>res\Sprs\object\object_weaponjian01</TexPath>
            <MaxStack>1</MaxStack>
            <Desc>一把通过吸收灵石和灵晶的精神能量而凝聚而成的剑，具有自身的精神聚集效果，可以让使用者无需气就能从空中发动攻击，并且具有隔离温度的特殊效果。</Desc>
            <Item Lable="Weapon">
                <NotFengshuiItem>1</NotFengshuiItem>
                <NotRandom>1</NotRandom>
                <FabaoSuffix>Sword</FabaoSuffix>
                <PhysicalLables><li>Sharp</li></PhysicalLables>
                <BeMade>
                    <WorkToMake>600</WorkToMake>
                    <StuffCategories>
                        <Stuff name="MetalBlock"/>
                        <Stuff name="RockBlock"/>
                        <Stuff name="WoodBlock"/>
                    </StuffCategories>
                    <CostStuffCount>5</CostStuffCount>
                </BeMade>
                <Equip>
                    <Damage>300</Damage>
                    <AttackSpeed>1.5</AttackSpeed>
                    <AttackRange>10</AttackRange>
                    <ArmorLingShield>0.05</ArmorLingShield>
                    <TemperatureMaxAdd>50</TemperatureMaxAdd>
                    <TemperatureMinAdd>-50</TemperatureMinAdd>
                    <AtkDamage>
                        <li PartKind="Flesh" Name="Cut1" Rate="0.1"/>
                        <li PartKind="Meridian" Name="MeridianCut" Rate="0.5"/>
                        <li PartKind="Organ" Name="VisceralCut" Rate="0.4"/>
                    </AtkDamage>
                    <AtkAnis>
                        <li Name="LJpugong1" HitPoint="11"/>
                        <li Name="LJpugong2" HitPoint="9"/>
                        <li Name="LJpugong3" HitPoint="15"/>
                        <li Name="LJpugong4" HitPoint="9"/>
                    </AtkAnis>
                    <WeaponKind>Sword</WeaponKind>
                    <ModPath>Mod/Prop/Weapon/weapon_jian1</ModPath>
                </Equip>
            </Item>
            <Ling>
                <AddionLing>1000</AddionLing>
                <AddionRadius>4</AddionRadius>
                <AddionFailing>0.9</AddionFailing>
                <AddionFailRadius>2</AddionFailRadius>
                <Attenuation>0.05</Attenuation>
                <Absorption>1.5</Absorption>
                <Accommodate>100</Accommodate>
            </Ling>
            <Light>
                <Value>20</Value>
                <Failing>0.6</Failing>
                <FailRadius>1</FailRadius>
                <Radius>1</Radius>
                <Color>94C8DAFF</Color>
            </Light>
        </ThingDef>

        <ThingDef Type="Item" Name="my_Dan_TXD" Parent="DanBase">
            <ThingName>天心丹</ThingName>
            <TexPath>res\Sprs\object\object_XIAOdanyao02</TexPath>
            <Desc>永久提升心情与心境基礎值 200 点。</Desc>
            <Tags><Tag Name="PracticeFood" Level="2"/></Tags>
            <Rate>6</Rate>
            <Beauty>10</Beauty>
            <ElementKind>Shui</ElementKind>
            <Item Lable="Dan">
                <NotFengshuiItem>1</NotFengshuiItem>
                <NotRandom>1</NotRandom>
                <PhysicalLables><li>Smooth1</li><li>Hard1</li><li>Light1</li></PhysicalLables>
                <Elixir>
                    <Modifier>my_TXD</Modifier>
                    <Fesistance>1</Fesistance>
                </Elixir>
                <BeMade>
                    <WorkToMake>20</WorkToMake>
                    <CostItems><Item name="Item_Water" count="1"/></CostItems>
                </BeMade>
            </Item>
            <Element><Kind>Shui</Kind><Value>50</Value><Radius>2</Radius></Element>
        </ThingDef>

        <ThingDef Type="Item" Name="Item_LingCloth">
